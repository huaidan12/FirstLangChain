#!/bin/bash
# 阿里云函数计算 FC 3.0 Custom Runtime 入口
# FC 会通过环境变量 CA_PORT（默认 9000）告知 uvicorn 应该监听的端口

set -e

PORT="${CA_PORT:-9000}"

# 把 _deps 加入 Python 模块搜索路径（依赖由 build.sh 在部署前装到这里）
export PYTHONPATH="${PWD}/_deps:${PYTHONPATH:-}"

exec python3 -m uvicorn main:app \
  --host 0.0.0.0 \
  --port "${PORT}" \
  --workers 1 \
  --log-level info
